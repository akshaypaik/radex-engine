# ─── Server ───────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ─── Scanner ───────────────────────────────────────────────
# Set to 'false' to skip auto-scan on server startup
SCAN_ON_BOOT=true

# Cron: Mon-Fri 4:00 PM IST (10:30 UTC)
SCAN_CRON=30 10 * * 1-5

# Scanner tuning (optional — defaults are sensible)
VOL_SURGE_THRESHOLD=1.5
MIN_RESIST_TOUCHES=2
RESIST_TOLERANCE_PCT=0.02
MULTI_YEAR_LOOKBACK=3
MIN_BREAKOUT_PCT=0.005
MAX_CONCURRENT=5

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
